{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install",
      "type": "shell",
      "command": "pnpm install",
      "problemMatcher": []
    },
    {
      "label": "dev:full",
      "dependsOn": ["dev:api", "dev:web"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "dev:api",
      "type": "shell",
      "command": "pnpm dev:api",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "API listening on http://localhost:3001"
        }
      }
    },
    {
      "label": "dev:web",
      "type": "shell",
      "command": "pnpm dev:web",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:.*http://localhost:3000"
        }
      }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "lint:fix",
      "type": "shell",
      "command": "pnpm lint:fix",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "format",
      "type": "shell",
      "command": "pnpm format",
      "problemMatcher": []
    },
    {
      "label": "check-types",
      "type": "shell",
      "command": "pnpm check-types",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "test:api",
      "type": "shell",
      "command": "pnpm test",
      "problemMatcher": []
    },
    {
      "label": "test:web",
      "type": "shell",
      "command": "pnpm test:web",
      "problemMatcher": []
    },
    {
      "label": "build:api",
      "type": "shell",
      "command": "pnpm build:api",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build:web",
      "type": "shell",
      "command": "pnpm build:web",
      "problemMatcher": ["$tsc"]
    }
  ]
}
