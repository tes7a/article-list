{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Browser: Web",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web",
      "preLaunchTask": "dev:web"
    },
    {
      "name": "API: Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:api",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Full Stack + Browser",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web",
      "preLaunchTask": "dev:full"
    }
  ],
  "compounds": [
    {
      "name": "Run Full Stack",
      "configurations": ["API: Dev Server", "Browser: Web"]
    }
  ]
}
